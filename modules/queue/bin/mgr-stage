#!/usr/bin/env bash
# mgr-stage — populate a prompt template into $POD_INBOX/<task-id>/prompt.txt.
#
# Usage:
#   mgr-stage <template-name> --id <task-id> [<key>=<value>]...
#   mgr-stage <template-name>                [<key>=<value>]...   # auto-id
#
# Template-name: one of audit|execute|investigate|plan (or any file at
# $POD_INBOX/_templates/<name>.tpl.txt). The queue module's own templates live
# in modules/queue/templates/; copy or symlink them into $POD_INBOX/_templates
# at setup so they resolve here.
#
# Substitution: every {{key}} in the template is replaced with the matching
# value. {{task_id}} is always available (the resolved task id).
#
# Returns the task-id on stdout (one line, no decoration) so the caller can
# pipe it into mgr-queue / mgr-dispatch.
#
# Examples:
#   tid=$(mgr-stage audit --id rename-audit-1 \
#                         context="Audit prefixed names ..." \
#                         task_body="Find every ..." \
#                         categories="rename | keep | drop")
#   echo "Staged: $tid"

set -euo pipefail
POD_BIN="$(cd "$(dirname "$0")/../../../bin" && pwd)"; . "$POD_BIN/_pod-paths.sh"

TEMPLATES_DIR="$POD_INBOX/_templates"
INBOX_ROOT="$POD_INBOX"

if [ $# -lt 1 ]; then
  echo "usage: mgr-stage <template-name> [--id <task-id>] [<key>=<value>]..." >&2
  exit 2
fi

TEMPLATE_NAME="$1"; shift
pod_valid_component "$TEMPLATE_NAME" || {
  echo "ERROR: invalid template name '$TEMPLATE_NAME'" >&2
  exit 2
}
# Look in the inbox's _templates first (user-customized), then fall back to the queue
# module's shipped templates — so the queue works out of the box with no seeding step.
TEMPLATE_PATH="${TEMPLATES_DIR}/${TEMPLATE_NAME}.tpl.txt"
[ -f "$TEMPLATE_PATH" ] || TEMPLATE_PATH="${POD_MODULES}/queue/templates/${TEMPLATE_NAME}.tpl.txt"
[ -f "$TEMPLATE_PATH" ] || { echo "ERROR: template '$TEMPLATE_NAME' not found in ${TEMPLATES_DIR} or ${POD_MODULES}/queue/templates" >&2; exit 1; }

TASK_ID=""
KV_PAIRS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --id)
      [ "$#" -ge 2 ] || { echo "ERROR: --id requires a value" >&2; exit 2; }
      TASK_ID="$2"; shift 2 ;;
    *=*)  KV_PAIRS+=("$1"); shift ;;
    *)    echo "ERROR: unrecognized arg: $1 (expected --id <id> or key=value)" >&2; exit 2 ;;
  esac
done

if [ -n "$TASK_ID" ]; then
  pod_valid_component "$TASK_ID" || {
    echo "ERROR: invalid task id '$TASK_ID' (use letters, digits, dot, underscore or hyphen)" >&2
    exit 2
  }
fi

# Auto-allocate task-id if not given: <template-name>-<N> where N is the next
# free integer. The mkdir IS the claim — it fails if another stager already took
# that N — so two concurrent auto-id runs can never share a task dir (a plain
# [ -d ] scan would race between the test and the create).
if [ -z "$TASK_ID" ]; then
  mkdir -p "$INBOX_ROOT"
  N=1
  while :; do
    TASK_ID="${TEMPLATE_NAME}-${N}"
    mkdir "${INBOX_ROOT}/${TASK_ID}" 2>/dev/null && break
    N=$((N + 1))
    [ "$N" -gt 100000 ] && { echo "ERROR: could not allocate a task id under ${INBOX_ROOT}" >&2; exit 1; }
  done
  TASK_DIR="${INBOX_ROOT}/${TASK_ID}"
  PROMPT_PATH="${TASK_DIR}/prompt.txt"
else
  TASK_DIR="${INBOX_ROOT}/${TASK_ID}"
  PROMPT_PATH="${TASK_DIR}/prompt.txt"
  if ! mkdir "$TASK_DIR" 2>/dev/null; then
    echo "ERROR: ${TASK_DIR} already exists. Refuse to reuse task state. Use a different --id or remove the old task dir first." >&2
    exit 1
  fi
fi

# Read template into memory; substitute {{task_id}} and every key=value pair.
content="$(cat "$TEMPLATE_PATH")"

# Two-phase substitution so a VALUE that itself contains "{{key}}" is never
# re-expanded by a later key's pass (a single-pass loop is order-dependent and
# recursively expands such values). Phase 1 rewrites every recognized
# placeholder to a sentinel form; phase 2 swaps the sentinels for the literal
# values. Uses Bash parameter expansion (no sed regex hell).
S1=$'\001'; S2=$'\002'
content="${content//\{\{task_id\}\}/${S1}task_id${S2}}"
for kv in "${KV_PAIRS[@]:-}"; do
  [ -z "$kv" ] && continue
  key="${kv%%=*}"
  # The key becomes a glob pattern in the substitution below; a key with glob
  # metachars (* ? [) would mis-match or eat surrounding text. Safe charset only.
  case "$key" in ''|*[!A-Za-z0-9_]*) echo "WARN: skipping key with unsupported chars: '$key' (allowed: A-Za-z0-9_)" >&2; continue ;; esac
  content="${content//\{\{${key}\}\}/${S1}${key}${S2}}"
done
content="${content//${S1}task_id${S2}/$TASK_ID}"
for kv in "${KV_PAIRS[@]:-}"; do
  [ -z "$kv" ] && continue
  key="${kv%%=*}"
  val="${kv#*=}"
  case "$key" in ''|*[!A-Za-z0-9_]*) continue ;; esac
  content="${content//${S1}${key}${S2}/$val}"
done

# Warn (but don't fail) if any {{key}} placeholders remain unsubstituted.
remaining_keys=$(printf '%s' "$content" | grep -oE '\{\{[a-zA-Z0-9_]+\}\}' | sort -u || true)
if [ -n "$remaining_keys" ]; then
  echo "WARN: unsubstituted placeholders in ${PROMPT_PATH}: $(printf '%s\n' "$remaining_keys" | tr '\n' ' ')" >&2
fi

printf '%s' "$content" > "$PROMPT_PATH"

# (durability layer removed — staged prompts live only under $POD_INBOX.)

# Print task-id to stdout (single line, parseable).
echo "$TASK_ID"
