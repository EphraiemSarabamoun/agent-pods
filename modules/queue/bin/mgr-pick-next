#!/usr/bin/env bash
# mgr-pick-next — composite: poll for completions, then dispatch the
# highest-priority queued task to any worker that just freed (or any
# already-idle worker).
#
# Designed to be called at the top of every manager Bash tool call so
# the queue keeps draining without explicit per-step bookkeeping.
#
# Usage:
#   mgr-pick-next                # poll + dispatch one if a worker is free
#   mgr-pick-next --all-idle     # dispatch to EVERY idle worker (drains
#                                # multiple queue entries in one shot if
#                                # there are queue items waiting)
#   mgr-pick-next --print-only   # print what would happen, fire nothing

set -euo pipefail
QBIN="$(cd "$(dirname "$0")" && pwd)"             # sibling mgr-* live here
POD_BIN="$(cd "$QBIN/../../../bin" && pwd)"; . "$POD_BIN/_pod-paths.sh"
. "$POD_BIN/_mgr-runtime.sh"                       # mgr_current_pod, mgr_full_auto
T="$POD_TMUX"

WORKERS_PATH="$POD_STATE/workers.json"

ALL_IDLE=0
PRINT_ONLY=0
for arg in "$@"; do
  case "$arg" in
    --all-idle)   ALL_IDLE=1 ;;
    --print-only) PRINT_ONLY=1 ;;
    *) echo "ERROR: unrecognized arg: $arg" >&2; exit 2 ;;
  esac
done

# Step 1: poll for newly-completed tasks (frees workers if any). This runs in BOTH
# modes — manual mode still tracks completions; it just won't auto-dispatch below.
echo "==> Polling for completions"
"$QBIN/mgr-poll"

# FULL AUTO gate: only AUTO-dispatch when this pod's switch is on. Fail-OPEN for
# non-pods (plain tmux / no @is_pod stamp) so the queue works outside a stamped pod.
# In MANUAL mode the queue holds — dispatch by hand with mgr-dispatch --tmux-window.
POD_SESS="$(mgr_current_pod)"
POD_SESS="$(mgr_pod_component "$POD_SESS")" || exit 2
QUEUE_DIR="$(mgr_queue_dir "$POD_SESS")"
if ! mgr_full_auto "$POD_SESS"; then
  echo "==> FULL AUTO is OFF for pod '$POD_SESS' — manual mode, holding the queue"
  echo "    (dispatch by hand: mgr-dispatch --tmux-window <@id>)"
  exit 0
fi

# Step 2: count LIVE idle workers + queue depth. The registry's idle claims can
# go stale (a window killed out from under it, a state flip a sweep missed), so
# a row only counts when its window is alive, in THIS pod, and the live
# @cc_state agrees — the same filter mgr-dispatch applies when it picks, so the
# count here never promises a worker that dispatch will then refuse.
live_idle_count() {
  n=0
  for w in $(jq -r --arg pod "$POD_SESS" '.workers[]
      | select(.tmux_session==$pod and .status=="idle")
      | .tmux_window // empty' "$WORKERS_PATH" 2>/dev/null); do
    [ -n "$w" ] || continue
    [ "$("$T" display-message -p -t "$w" '#{session_name}' 2>/dev/null || true)" = "$POD_SESS" ] || continue
    [ "$("$T" show-options -w -t "$w" -qv @cc_state 2>/dev/null || true)" = "idle" ] || continue
    case "$("$T" show-options -w -t "$w" -qv @agent_id 2>/dev/null || true)" in
      ""|generic-shell) continue ;;
    esac
    n=$((n + 1))
  done
  echo "$n"
}
idle_count=$(live_idle_count)
queue_count=0
for qf in "$QUEUE_DIR"/*.json; do
  [ -e "$qf" ] || continue
  queue_count=$((queue_count + 1))
done
echo "==> pod: ${POD_SESS}, live idle workers: ${idle_count}, queue depth: ${queue_count}"

if [ "$idle_count" -eq 0 ]; then
  echo "    no live idle workers — nothing to dispatch"
  exit 0
fi
if [ "$queue_count" -eq 0 ]; then
  echo "    queue empty — nothing to dispatch"
  exit 0
fi

# Step 3: dispatch up to N workers' worth of queued tasks.
n=1
[ "$ALL_IDLE" -eq 1 ] && n=$idle_count
[ "$n" -gt "$queue_count" ] && n=$queue_count

dispatch_args=()
[ "$PRINT_ONLY" -eq 1 ] && dispatch_args+=("--print-only")

i=0
while [ "$i" -lt "$n" ]; do
  echo ""
  # Tolerate a single dispatch failure (a ghost-quarantine exit, a worker whose
  # state flipped mid-sweep) so the remaining idle workers still get tasks
  # instead of the whole --all-idle batch aborting under set -e.
  "$QBIN/mgr-dispatch" ${dispatch_args[@]+"${dispatch_args[@]}"} \
    || echo "    (dispatch attempt $((i + 1)) of ${n} returned $? — continuing)" >&2
  i=$((i + 1))
done
