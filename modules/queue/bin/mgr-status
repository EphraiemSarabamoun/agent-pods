#!/usr/bin/env bash
# mgr-status — pretty-print the queue state: in-flight workers, queued tasks,
# recent completions.
#
# Usage:
#   mgr-status            # human-readable
#   mgr-status --json     # machine-readable

set -euo pipefail
POD_BIN="$(cd "$(dirname "$0")/../../../bin" && pwd)"; . "$POD_BIN/_pod-paths.sh"
. "$POD_BIN/_mgr-runtime.sh"                       # mgr_current_pod, mgr_pod_auto_state

INBOX_ROOT="$POD_INBOX"
WORKERS_PATH="$POD_STATE/workers.json"
LOG_PATH="$POD_STATE/log.jsonl"

CURRENT_POD="$(mgr_current_pod)"
CURRENT_POD="$(mgr_pod_component "$CURRENT_POD")" || exit 2
QUEUE_DIR="$(mgr_queue_dir "$CURRENT_POD")"
DISPATCHED="$(mgr_dispatched_dir "$CURRENT_POD")"
AUTO_STATE="$(mgr_pod_auto_state "$CURRENT_POD")"   # on | off | none (non-pod)

EMIT_JSON=0
[ "${1:-}" = "--json" ] && EMIT_JSON=1

if [ "$EMIT_JSON" -eq 1 ]; then
  case "$AUTO_STATE" in
    on)  fa=true ;;
    off) fa=false ;;
    *)   fa=null ;;
  esac
  jq -n \
    --slurpfile workers "$WORKERS_PATH" \
    --argjson queue "$(ls "$QUEUE_DIR" 2>/dev/null | jq -R . | jq -s . || echo '[]')" \
    --arg inbox "$INBOX_ROOT" \
    --arg pod "$CURRENT_POD" \
    --argjson fa "$fa" \
    '{workers: [$workers[0].workers[] | select(.tmux_session==$pod)],
      queue_files: $queue, inbox_root: $inbox, pod:$pod, full_auto: $fa}'
  exit 0
fi

# the pod's FULL AUTO switch (pod-auto / the strip's ⚡ pill); hidden for non-pods
case "$AUTO_STATE" in
  on)  echo " mode: ⚡ FULL AUTO — the manager dispatches autonomously (pod: ${CURRENT_POD})" ;;
  off) echo " mode: ✋ MANUAL — automatic dispatch disabled (pod-auto on to flip)" ;;
esac
echo "================================================================"
echo " WORKERS"
echo "================================================================"
jq -r --arg pod "$CURRENT_POD" '.workers[] | select(.tmux_session==$pod)
  | "  " + (.tmux_window // "?") + " " + (.color // "") + " [" + (.label // "—") + "] " + .status + (if .current_task_id then " · " + .current_task_id else "" end) + (if .started_at then " · started " + .started_at else "" end)' "$WORKERS_PATH" 2>/dev/null
[ "$(jq --arg pod "$CURRENT_POD" '[.workers[]|select(.tmux_session==$pod)] | length' "$WORKERS_PATH" 2>/dev/null || echo 0)" -eq 0 ] && echo "  (no workers registered — spawn one via the + button or pod-add-worker)"

echo ""
echo "================================================================"
echo " QUEUE (highest priority / earliest first)"
echo "================================================================"
queue_files=$(ls "$QUEUE_DIR" 2>/dev/null | sort)
if [ -z "$queue_files" ]; then
  echo "  (queue empty)"
else
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    fp="${QUEUE_DIR}/${f}"
    tid=$(jq -r .task_id "$fp")
    pri=$(jq -r .priority "$fp")
    desc=$(jq -r '.description // ""' "$fp")
    tpl=$(jq -r '.template // ""' "$fp")
    printf "  pri=%-3s %-40s %-15s %s\n" "$pri" "$tid" "[$tpl]" "$desc"
  done <<< "$queue_files"
fi

echo ""
echo "================================================================"
echo " RECENT COMPLETIONS (last 10)"
echo "================================================================"
if [ -s "$LOG_PATH" ]; then
  jq -c --arg pod "$CURRENT_POD" 'select(.event=="completed" and .pod==$pod)' \
    "$LOG_PATH" 2>/dev/null | tail -10 | jq -r '"  \(.ts)  \(.task_id)"'
else
  echo "  (no completions logged yet)"
fi

echo ""
echo "================================================================"
echo " DISPATCHED ARCHIVE COUNT: $(ls "$DISPATCHED" 2>/dev/null | wc -l | tr -d ' ')"
echo "================================================================"
