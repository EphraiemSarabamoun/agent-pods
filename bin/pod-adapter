#!/usr/bin/env python3
"""pod-adapter — the single point of access to the agent catalog (adapters/*.toml).

Every other script that needs to know "how do I launch agent X", "which agent is in
this pane", "what's the pretty card for X", or "what models/efforts does X have" calls
THIS tool instead of parsing TOML itself. That keeps the catalog format in one place
and lets a user drop a new adapter file in ~/.config/pod/adapters/ without editing code.

Adapters load from $POD_ADAPTERS_DIR (repo defaults) then $POD_USER_ADAPTERS (user
overrides); same `[agent].id` -> the user file wins. Requires Python 3.11+ (tomllib).

Subcommands:
  list [--available]            ids, one per line (--available = base_cmd resolves on PATH)
  detect <pane_cmd> [content]   id of the adapter that claims this pane (priority order)
  launch <id> [--model S] [--effort S]   the launch command (space-joined argv tokens)
  card <id> [--model S] [--effort S] [--suffix S]   "Label · Model · effort · suffix"
  models <id>                   "slug\tlabel" per locally discovered model, plus
                                the inherited agent-default choice
  efforts <id> <model_slug>     "slug\tlabel" per effort
  resolve-effort <id> <model> [requested]  validate a saved effort, else empty
  refresh [id]                  re-query live discovery, busting the cache
  field <id> <key>              one scalar from [agent]/[launch]/[lifecycle]/[defaults]
  dump [--json]                 the whole resolved catalog (debug)

Exit 0 on a clean answer; non-zero (no output) when the id/field is unknown, so callers
can `x="$(pod-adapter ... )" || fallback`.
"""
import argparse
import glob
import json
import os
import re
import signal
import shlex
import shutil
import subprocess
import sys
import tempfile
import time

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover
    sys.stderr.write("pod-adapter: needs Python 3.11+ (tomllib). Found %s\n" % sys.version.split()[0])
    sys.exit(3)


SAFE_ADAPTER_ID = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$")


def _repo_root():
    # env wins (set by _pod-paths.sh); else resolve relative to this file (bin/..).
    r = os.environ.get("POD_REPO")
    if r:
        return r
    return os.path.dirname(os.path.dirname(os.path.abspath(os.path.realpath(__file__))))


def _adapter_dirs():
    root = _repo_root()
    repo = os.environ.get("POD_ADAPTERS_DIR") or os.path.join(root, "adapters")
    user = os.environ.get("POD_USER_ADAPTERS") or os.path.join(
        os.environ.get("POD_CONFIG_DIR", os.path.expanduser("~/.config/pod")), "adapters"
    )
    return repo, user


def load_adapters():
    """id -> adapter dict. Repo first, user dir overrides by id."""
    repo, user = _adapter_dirs()
    out = {}
    for d in (repo, user):
        if not d or not os.path.isdir(d):
            continue
        for path in sorted(glob.glob(os.path.join(d, "*.toml"))):
            if os.path.basename(path).startswith("_"):   # _schema.toml etc. are docs
                continue
            try:
                with open(path, "rb") as f:
                    data = tomllib.load(f)
            except Exception as e:
                sys.stderr.write("pod-adapter: skipping %s (%s)\n" % (path, e))
                continue
            ag = data.get("agent", {})
            aid = ag.get("id")
            if not aid:
                continue
            if not isinstance(aid, str) or not SAFE_ADAPTER_ID.fullmatch(aid):
                sys.stderr.write("pod-adapter: skipping %s (unsafe agent id %r)\n" % (path, aid))
                continue
            data["_path"] = path
            data["_id"] = aid
            out[aid] = data
    return out


# ---------------------------------------------------------------------------------
# Live model discovery. An adapter may carry an optional [discover] block that names
# a command which lists the agent's CURRENTLY served models (e.g. its local /model
# menu or cursor-agent --list-models). Discovery is authoritative:
# static [[models]] entries may annotate discovered rows but never assert availability.
# If discovery is absent or fails, the picker exposes only "Agent default (inherited)"
# and launches without a model flag.
#
# Only the models VARY across releases and machines, so only they are discovered.
# Effort ladders are a stable per-agent vocabulary that no CLI enumerates, so they
# stay declarative: [discover].efforts is applied to every discovered model (and a
# static [[models]] entry with a matching slug can override label/efforts).
#
# Results are cached under $POD_STATE/discover/<id>.json with a TTL, so the gear
# menu stays snappy; `pod-adapter refresh [id]` busts the cache and re-queries.

def _state_dir():
    runtime = os.environ.get("POD_TMP") or os.path.join(
        os.environ.get("TMPDIR", "/tmp"), "agent-pods-%d" % os.getuid())
    return os.environ.get("POD_STATE") or os.path.join(runtime, "state")


def _discover_cache_path(aid):
    return os.path.join(_state_dir(), "discover", "%s.json" % aid)


def _write_discovery_cache(path, models):
    """Write discovery results atomically with private runtime permissions."""
    parent = os.path.dirname(path)
    tmp = ""
    try:
        os.makedirs(parent, mode=0o700, exist_ok=True)
        os.chmod(parent, 0o700)
        fd, tmp = tempfile.mkstemp(prefix=".models-", suffix=".json", dir=parent)
        with os.fdopen(fd, "w") as f:
            json.dump({"ts": int(time.time()), "models": models}, f)
            f.flush()
            os.fsync(f.fileno())
        os.chmod(tmp, 0o600)
        os.replace(tmp, path)
    except OSError:
        if tmp:
            try:
                os.unlink(tmp)
            except OSError:
                pass


def _valid_discovery_rows(value):
    """Validate cached/discovered rows before they influence launch arguments."""
    if not isinstance(value, list):
        return None
    rows = []
    for item in value:
        if not isinstance(item, dict):
            return None
        slug, label, model = item.get("slug"), item.get("label"), item.get("model")
        if not all(isinstance(part, str) for part in (slug, label, model)) or not slug:
            return None
        rows.append({"slug": slug, "label": label or slug, "model": model})
    return rows or None


def _run_discovery(disc):
    """Run the adapter's discovery command and parse its model list.

    Returns [{slug, label, model}, ...] or None on any failure (so callers expose
    only the inherited agent default). The command runs via the shell, so a user can
    invoke the same agent wrapper on another machine when needed.
    """
    cmd = disc.get("models_cmd")
    if not cmd:
        return None
    fmt = disc.get("models_format", "regex")
    # default regex: "<id>" optionally followed by " - <label>"
    regex = disc.get("models_regex") or r"^(\S+)(?:\s+-\s+(.+))?$"
    try:
        pat = re.compile(regex)
    except re.error:
        return None
    # Prepend POD_BIN to PATH so models_cmd can call sibling discovery helpers even
    # before bin/ is symlinked onto the user's PATH.
    env = dict(os.environ)
    podbin = os.environ.get("POD_BIN") or os.path.dirname(os.path.abspath(__file__))
    env["PATH"] = podbin + os.pathsep + env.get("PATH", "")
    try:
        timeout = float(disc.get("timeout_s", 6))
        p = subprocess.Popen(cmd, shell=True, stdout=subprocess.PIPE,
                             stderr=subprocess.PIPE, text=True, env=env,
                             start_new_session=True)
        try:
            stdout, stderr = p.communicate(timeout=timeout)
        except subprocess.TimeoutExpired:
            # Killing only the shell leaves its child holding stdout/stderr open,
            # which makes communicate() wait forever. Kill the whole discovery
            # process group so a wedged CLI cannot freeze the picker.
            try:
                os.killpg(p.pid, signal.SIGKILL)
            except (OSError, AttributeError):
                p.kill()
            # A grandchild can escape the process group while retaining the pipe
            # descriptors. Never let that escaped process make discovery hang after
            # our advertised timeout: reap briefly, then close our pipe ends.
            try:
                p.communicate(timeout=1)
            except subprocess.TimeoutExpired:
                for stream in (p.stdout, p.stderr):
                    if stream is not None:
                        stream.close()
                try:
                    p.kill()
                    p.wait(timeout=1)
                except (OSError, subprocess.SubprocessError):
                    pass
            return None
        r = subprocess.CompletedProcess(cmd, p.returncode, stdout, stderr)
    except (subprocess.SubprocessError, OSError, ValueError):
        return None
    if r.returncode != 0:
        return None
    out, seen = [], set()
    for line in r.stdout.splitlines():
        if fmt == "tsv":
            fields = line.split("\t")
            if len(fields) < 2:
                continue
            mid = fields[0].strip()
            label = fields[1].strip() or mid
            model = fields[2].strip() if len(fields) >= 3 else mid
        else:
            m = pat.search(line)
            if not m:
                continue                   # header / blank / noise lines just skip
            mid = (m.group(1) or "").strip()
            label = mid
            if m.lastindex and m.lastindex >= 2 and m.group(2):
                label = m.group(2).strip()
            model = mid
        if not mid or mid in seen:
            continue
        seen.add(mid)
        out.append({"slug": mid, "label": label, "model": model})
    return _valid_discovery_rows(out)


def _cached_discovery(aid, disc):
    path = _discover_cache_path(aid)
    try:
        age = time.time() - os.stat(path).st_mtime
        if age < float(disc.get("ttl_s", 21600)):
            with open(path) as f:
                payload = json.load(f)
            if isinstance(payload, dict):
                cached = _valid_discovery_rows(payload.get("models"))
                if cached:
                    return cached
    except (OSError, TypeError, ValueError):
        pass
    models = _run_discovery(disc)
    if models:
        _write_discovery_cache(path, models)
    return models


def _merge_discovered(discovered, static, disc):
    """Discovered models are the spine; a static entry with the same slug lends its
    prettier label and its effort ladder. Otherwise the [discover].efforts default."""
    by_slug = {m.get("slug"): m for m in (static or [])}
    default_efforts = disc.get("efforts", []) or []
    out = []
    for d in discovered:
        s = by_slug.get(d["slug"]) or {}
        out.append({
            "slug": d["slug"],
            "model": d["model"],
            "label": s.get("label") or d["label"],
            "efforts": s.get("efforts") or default_efforts,
        })
    return out


def _inherited_model(adapter=None):
    disc = (adapter or {}).get("discover") or {}
    return {"slug": "inherit", "model": "",
            "label": "Agent default (inherited)",
            "efforts": disc.get("efforts", []) or []}


def models_of(adapter):
    """The effective model list, derived from the local agent when possible.

    A static entry can improve the label/effort metadata of a model that discovery
    actually returned, but it never creates an available model by itself.
    """
    if "_models" in adapter:
        return adapter["_models"]
    if not (adapter.get("launch", {}).get("model_arg") or []):
        adapter["_models"] = []
        return []
    static = adapter.get("models", []) or []
    disc = adapter.get("discover") or {}
    resolved = [_inherited_model(adapter)]
    if disc.get("models_cmd"):
        discovered = _cached_discovery(adapter.get("_id", ""), disc)
        if discovered:
            resolved += [m for m in _merge_discovered(discovered, static, disc)
                         if m.get("slug") != "inherit"]
    adapter["_models"] = resolved
    return resolved


def _model(adapter, slug):
    # Inheritance is a built-in semantic choice and never needs a potentially slow
    # discovery query just to prove it exists.
    if slug == "inherit" and (adapter.get("launch", {}).get("model_arg") or []):
        return _inherited_model(adapter)
    for m in models_of(adapter):
        if m.get("slug") == slug:
            return m
    # tolerant: match by the substituted provider model value too.
    for m in models_of(adapter):
        if slug and m.get("model") == slug:
            return m
    return None


def _effort(model, slug):
    for e in (model.get("efforts", []) or []) if model else []:
        if e.get("slug") == slug:
            return e
    return None


def cmd_list(adapters, args):
    for aid in sorted(adapters, key=lambda i: adapters[i].get("agent", {}).get("priority", 1000)):
        if args.available:
            base = adapters[aid].get("launch", {}).get("base_cmd", "")
            # generic-shell's base is a shell expansion ("${SHELL:-...}") — always available.
            if not base or base.startswith("$") or shutil.which(_first_word(base)):
                print(aid)
        else:
            print(aid)


def _first_word(s):
    return s.split()[0] if s else s


def cmd_detect(adapters, args):
    pane_cmd = args.pane_cmd or ""
    content = args.content or ""
    order = sorted(adapters, key=lambda i: adapters[i].get("agent", {}).get("priority", 1000))

    def det(aid):
        return adapters[aid].get("detect", {})

    def rejected(aid):
        return bool(content) and any(re.search(p, content) for p in (det(aid).get("reject_content", []) or []))

    def cmd_pats(aid):
        # the catch-all '.*' is handled only in the final phase, never as a "specific" match.
        return [p for p in (det(aid).get("pane_cmd_patterns", []) or []) if p != ".*"]

    def con_pats(aid):
        return det(aid).get("content_patterns", []) or []

    # 4-phase, so the right agent wins and CLAUDE is never mis-ID'd by transcript text:
    #  1. specific pane_cmd of agents identified PURELY by pane_cmd (claude's version
    #     string, a unique binary name) — highest confidence; checked before any content
    #     so a claude window whose transcript merely mentions "codex" stays claude.
    #  2. content patterns — disambiguates the node/python TUIs (codex vs cursor vs ...).
    #  3. specific pane_cmd of agents that ALSO have content patterns — weak fallback
    #     (a bare "node" with no identifying content -> the highest-priority node agent).
    #  4. the catch-all ('.*' -> generic-shell): any pane is a first-class podmate.
    for aid in order:
        if rejected(aid):
            continue
        if not con_pats(aid) and cmd_pats(aid) and any(re.search(p, pane_cmd) for p in cmd_pats(aid)):
            print(aid)
            return
    for aid in order:
        if rejected(aid):
            continue
        if content and con_pats(aid) and any(re.search(p, content) for p in con_pats(aid)):
            print(aid)
            return
    for aid in order:
        if rejected(aid):
            continue
        if cmd_pats(aid) and any(re.search(p, pane_cmd) for p in cmd_pats(aid)):
            print(aid)
            return
    for aid in order:
        if ".*" in (det(aid).get("pane_cmd_patterns", []) or []):
            print(aid)
            return
    sys.exit(1)


def cmd_launch(adapters, args):
    a = adapters.get(args.id)
    if not a:
        sys.exit(1)
    launch = a.get("launch", {})
    base = launch.get("base_cmd", "")
    if base == "${SHELL:-/bin/bash}":
        base = os.environ.get("SHELL") or "/bin/bash"
    tokens = [base]
    requested = args.model
    m = _model(a, requested) if requested else None
    if requested and not m:
        sys.exit(1)
    if m and m.get("model"):
        for t in launch.get("model_arg", []) or []:
            tokens.append(t.replace("{model}", m["model"]))
    # effort is a CLI-side knob independent of which backend serves the model —
    em = m or _model(a, a.get("defaults", {}).get("model", ""))
    e = _effort(em, args.effort) if (em and args.effort) else None
    if args.effort and not e:
        sys.exit(1)
    if e and e.get("value"):
        for t in launch.get("effort_arg", []) or []:
            tokens.append(t.replace("{effort}", e["value"]))
    print(shlex.join([t for t in tokens if t]))


def cmd_card(adapters, args):
    a = adapters.get(args.id)
    label = (a.get("agent", {}).get("label") if a else None) or args.id
    model_label = ""
    effort_label = ""
    if a:
        requested = args.model
        m = _model(a, requested) if requested else None
        if m:
            model_label = m.get("label", requested or "")
        elif requested:
            model_label = requested
        em = m or _model(a, a.get("defaults", {}).get("model", ""))
        if em is None:
            em = next(iter(models_of(a)), None)
        e = _effort(em, args.effort) if args.effort else None
        if e:
            effort_label = e.get("label", args.effort or "")
    else:
        model_label = args.model or ""
        effort_label = args.effort or ""
    parts = [label, model_label, effort_label, args.suffix]
    print(" · ".join(x for x in parts if x))


def cmd_models(adapters, args):
    a = adapters.get(args.id)
    if not a:
        sys.exit(1)
    for m in models_of(a):
        print("%s\t%s" % (m.get("slug", ""), m.get("label", "")))


def cmd_resolve_model(adapters, args):
    """Return a currently available semantic model slug.

    A removed/stale saved choice resolves to ``inherit`` instead of replaying a model
    the local agent no longer advertises.
    """
    a = adapters.get(args.id)
    if not a:
        sys.exit(1)
    if not (a.get("launch", {}).get("model_arg") or []):
        print("")
        return
    requested = args.requested or a.get("defaults", {}).get("model", "inherit")
    if requested == "inherit":
        print("inherit")
        return
    print(requested if _model(a, requested) else "inherit")


def cmd_resolve_effort(adapters, args):
    """Return a currently valid semantic effort slug, or an empty string."""
    a = adapters.get(args.id)
    if not a:
        sys.exit(1)
    model_slug = args.model or a.get("defaults", {}).get("model", "inherit")
    model = _model(a, model_slug)
    requested = args.requested or a.get("defaults", {}).get("effort", "")
    print(requested if requested and _effort(model, requested) else "")


def cmd_refresh(adapters, args):
    """Bust the discovery cache and re-query. With no id, refreshes every adapter
    that has a [discover] block. Prints "<id>\\t<n> models" per refreshed agent."""
    ids = [args.id] if args.id else list(adapters)
    any_disc = False
    failed = False
    for aid in ids:
        a = adapters.get(aid)
        if not a:
            continue
        disc = a.get("discover") or {}
        if not disc.get("models_cmd"):
            continue
        any_disc = True
        try:
            os.remove(_discover_cache_path(aid))
        except OSError:
            pass
        models = _run_discovery(disc)
        if models:
            path = _discover_cache_path(aid)
            _write_discovery_cache(path, models)
            print("%s\t%d models" % (aid, len(models)))
        else:
            failed = True
            sys.stderr.write("%s: discovery returned nothing; inherited default only\n" % aid)
    if not any_disc:
        sys.stderr.write("pod-adapter refresh: no adapter with a [discover] block%s\n"
                         % ("" if not args.id else " for '%s'" % args.id))
        sys.exit(1)
    if failed:
        sys.exit(1)


def cmd_efforts(adapters, args):
    a = adapters.get(args.id)
    if not a:
        sys.exit(1)
    m = _model(a, args.model)
    if not m:
        sys.exit(1)
    for e in m.get("efforts", []) or []:
        print("%s\t%s" % (e.get("slug", ""), e.get("label", "")))


def cmd_field(adapters, args):
    a = adapters.get(args.id)
    if not a:
        sys.exit(1)
    for section in ("agent", "launch", "lifecycle", "defaults", "discover"):
        if args.key in a.get(section, {}):
            v = a[section][args.key]
            if isinstance(v, bool):
                print("true" if v else "false")
            elif isinstance(v, list):
                print(" ".join(str(x) for x in v))
            else:
                print(v)
            return
    sys.exit(1)


def cmd_dump(adapters, args):
    import json
    print(json.dumps(adapters, indent=2, default=str))


def main():
    p = argparse.ArgumentParser(prog="pod-adapter")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("list")
    s.add_argument("--available", action="store_true")
    s = sub.add_parser("detect")
    s.add_argument("pane_cmd")
    s.add_argument("content", nargs="?", default="")
    s = sub.add_parser("launch")
    s.add_argument("id")
    s.add_argument("--model", default="")
    s.add_argument("--effort", default="")
    s = sub.add_parser("card")
    s.add_argument("id")
    s.add_argument("--model", default="")
    s.add_argument("--effort", default="")
    s.add_argument("--suffix", default="")
    s = sub.add_parser("models")
    s.add_argument("id")
    s = sub.add_parser("resolve-model")
    s.add_argument("id")
    s.add_argument("requested", nargs="?", default="")
    s = sub.add_parser("resolve-effort")
    s.add_argument("id")
    s.add_argument("model", nargs="?", default="")
    s.add_argument("requested", nargs="?", default="")
    s = sub.add_parser("efforts")
    s.add_argument("id")
    s.add_argument("model")
    s = sub.add_parser("refresh")
    s.add_argument("id", nargs="?", default="")
    s = sub.add_parser("field")
    s.add_argument("id")
    s.add_argument("key")
    s = sub.add_parser("dump")
    s.add_argument("--json", action="store_true")

    args = p.parse_args()
    adapters = load_adapters()
    {
        "list": cmd_list, "detect": cmd_detect, "launch": cmd_launch, "card": cmd_card,
        "models": cmd_models, "efforts": cmd_efforts, "field": cmd_field, "dump": cmd_dump,
        "refresh": cmd_refresh, "resolve-model": cmd_resolve_model,
        "resolve-effort": cmd_resolve_effort,
    }[args.cmd](adapters, args)


if __name__ == "__main__":
    main()
