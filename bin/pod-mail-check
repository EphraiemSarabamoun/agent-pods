#!/usr/bin/env bash
# pod-mail-check <hook-event> — SessionStart/UserPromptSubmit hook helper.
#
# AUTO-DELIVERY: if THIS instance has unread pod-mail, inject the FULL messages as
# additionalContext at its next turn, drain the mailbox (archive to <id>.read, same
# as pod-mail), and clear the tab's red unread badge — so "agent got prompted"
# always means "mail delivered and badge gone". Still non-intrusive: context, never
# typed input. Silent if no mail or not in a pod. pod-mail remains the manual read
# path (it mostly finds an empty box now).
#
# Ordering matters: emit-capability is checked BEFORE the drain (no jq -> no
# drain), so messages can never vanish without reaching the model's context.
set -u
EVENT="${1:-UserPromptSubmit}"
command -v tmux >/dev/null 2>&1 || exit 0
[ -n "${TMUX:-}" ] || exit 0
pane="${TMUX_PANE:-}"; [ -n "$pane" ] || exit 0
# per-pod mailbox (the helper resolves THIS pod from $TMUX_PANE). Guarded so a
# missing helper just means "no delivery", never a broken hook.
POD_BIN="$(cd "$(dirname "$0")" && pwd)"; . "$POD_BIN/_pod-paths.sh" 2>/dev/null || exit 0
. "$POD_BIN/_pod-common.sh" 2>/dev/null || exit 0
T="$POD_TMUX"
me_id="$("$T" display-message -p -t "$pane" '#{window_id}' 2>/dev/null)" || exit 0
mbox="$(pod_mbox "$me_id")"
if [ ! -s "$mbox" ]; then  # no mail: clear any stale badge (self-heal), stay silent
  "$T" set-option -uw -t "$me_id" @unread 2>/dev/null || true
  exit 0
fi
# (no jq gate: pod_emit_ctx below can always emit — jq, python3, or raw stdout)
# Atomic drain (pod-mail's pattern): mv the mailbox aside FIRST; a concurrent
# pod-tell append re-creates a fresh mbox, so nothing lands in a half-read box.
snap="${mbox}.reading.$$"
mv "$mbox" "$snap" 2>/dev/null || exit 0
# Count MESSAGES, not lines: direct/@everyone entries begin with a "[HH:MM] "
# stamp; quiet-chat entries (pod-tell chat) carry an "fyi " prefix and are
# counted separately — they never badge, but they deliver all the same.
n="$(grep -c '^\[' "$snap" 2>/dev/null)"; n="${n:-0}"
nf="$(grep -c '^fyi ' "$snap" 2>/dev/null)"; nf="${nf:-0}"
[ "$nf" -gt 0 ] && n="$n (+$nf fyi)"
body="$(cat "$snap")"
cat "$snap" >> "$(pod_read "$me_id")" 2>/dev/null || true
rm -f "$snap"
# delivered -> the tab badge clears NOW (this prompt = the read). Unset, never
# "0" (#{?} treats the string "0" as true).
"$T" set-option -uw -t "$me_id" @unread 2>/dev/null || true
"$T" refresh-client -S 2>/dev/null || true
msg="You have ${n} pod-mail message(s), delivered here and cleared (archived to your .read log):
${body}"
pod_emit_ctx "$EVENT" "$msg"
exit 0
