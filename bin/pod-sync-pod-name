#!/usr/bin/env bash
# pod-sync-pod-name <new_session_name> — session-renamed hook handler: make a pod
# RENAME first-class, the way pod-sync-label does for worker-tab renames.
#
# tmux's session-renamed hook only tells us the NEW name (#{hook_session_name}); the
# OLD name comes from the @pod_name session option, which pod-launch stamps at
# creation and this script re-stamps after every rename. On a rename it:
#
#   1. moves $POD_COMMS/<old> -> <new>  (chat feed, mailboxes, leases, work logs —
#      everything _pod-common.sh keys by session name; without the move the pod's
#      comms history would orphan and the launch-time gc would delete it)
#   2. updates the session env POD_SESSION (future panes; running panes keep a stale
#      copy, which is fine — pod_name()/mgr_current_pod/pod-add-worker resolve
#      live-first and only trust POD_SESSION when that session exists)
#   3. rewrites tmux_group.json if this pod is the recorded PRIMARY (the MCP +
#      headless mgr-* helpers follow that file)
#   4. re-stamps @pod_name and logs the rename to the pod's channel feed
#
# Guarded by @is_pod: renaming a non-pod tmux session is a no-op here. bash 3.2 safe.
set -uo pipefail
POD_BIN="$(cd "$(dirname "$0")" && pwd)"; . "$POD_BIN/_pod-paths.sh"; . "$POD_BIN/_pod-common.sh"
T="$POD_TMUX"
STATE_GRP="$POD_STATE/tmux_group.json"

# NOTE on targeting: has-session accepts the "=" exact-match prefix, but on tmux 3.6b
# set-option/show-options REJECT it ("no such session: =x"). cmd-find tries an exact
# name match before prefix matching, so after the exact has-session guard the
# bare-name targets below resolve to the right session deterministically.
new="${1:-}"
[ -n "$new" ] || exit 0
"$T" has-session -t "=$new" 2>/dev/null || exit 0
[ "$("$T" show-options -t "$new" -qv @is_pod 2>/dev/null)" = "1" ] || exit 0

old="$("$T" show-options -t "$new" -qv @pod_name 2>/dev/null)"

# Session names are also filesystem namespace keys. Refuse non-canonical names so
# distinct tmux names can never collapse onto the same comms directory.
if ! pod_valid_component "$new"; then
  if [ -n "$old" ] && [ "$old" != "$new" ]; then
    "$T" rename-session -t "$new" "$old" 2>/dev/null || true
  fi
  echo "pod-sync-pod-name: refused invalid pod name '$new'" >&2
  exit 1
fi

# always leave the stamp + env consistent with the live name
"$T" set-option -t "$new" @pod_name "$new" 2>/dev/null || true
"$T" set-environment -t "$new" POD_SESSION "$new" 2>/dev/null || true

# nothing else to migrate when there's no prior name (pre-@pod_name pod adopted live)
# or the "rename" is a no-op
[ -n "$old" ] && [ "$old" != "$new" ] || exit 0

# 1. per-pod comms/lease subtree follows the pod
od="$(pod_dir_for "$old")"; nd="$(pod_dir_for "$new")"
if [ -d "$od" ] && [ ! -e "$nd" ]; then
  mv "$od" "$nd" 2>/dev/null || true
fi

# Queue ownership follows the pod too. Each namespace contains globally-unique task
# ids, so a target collision is left untouched and reported instead of overwritten.
migrate_namespace_dir() {
  local src="$1" dst="$2" entry base
  [ -d "$src" ] || return 0
  mkdir -p "$dst" 2>/dev/null || return 1
  for entry in "$src"/*; do
    [ -e "$entry" ] || continue
    base="${entry##*/}"
    if [ -e "$dst/$base" ]; then
      echo "pod-sync-pod-name: queue-state collision left at $entry" >&2
      continue
    fi
    mv "$entry" "$dst/$base" 2>/dev/null || true
  done
  rmdir "$src" 2>/dev/null || true
}
migrate_namespace_dir "$POD_INBOX/_queue/$old" "$POD_INBOX/_queue/$new"
migrate_namespace_dir "$POD_STATE/dispatched/$old" "$POD_STATE/dispatched/$new"
migrate_namespace_dir "$POD_STATE/completed/$old" "$POD_STATE/completed/$new"

mkdir -p "$POD_STATE/pod-tasks" 2>/dev/null || true
for suffix in .json .wait-completions; do
  src="$POD_STATE/pod-tasks/${old}${suffix}"
  dst="$POD_STATE/pod-tasks/${new}${suffix}"
  [ -e "$src" ] || continue
  if [ -e "$dst" ]; then
    echo "pod-sync-pod-name: task-loop state collision left at $src" >&2
  else
    mv "$src" "$dst" 2>/dev/null || true
  fi
done

# Registry rows follow a rename too; otherwise queue/MCP cross-pod checks would
# correctly reject every worker because its row retained the old session name.
if [ -f "$POD_STATE/workers.json" ]; then
  "$POD_BIN/pod-workers-json" --path "$POD_STATE/workers.json" rename-session "$old" "$new" \
    >/dev/null 2>&1 || true
fi

# 2. primary-pod record follows too (only if it pointed at the OLD name; a secondary
# pod's rename must not clobber the primary's record). Share pod-launch's lock and use
# an atomic replace so a concurrent launch/rename cannot tear or lose the JSON.
if [ -f "$STATE_GRP" ]; then
python3 - "$STATE_GRP" "$old" "$new" <<'PY'
import fcntl, json, os, sys, tempfile
path, old, new = sys.argv[1:4]
with open(path + ".lock", "a+") as lock:
    fcntl.flock(lock, fcntl.LOCK_EX)
    try:
        with open(path) as source:
            data = json.load(source)
        if not isinstance(data, dict) or data.get("session") != old:
            raise SystemExit(0)
        data["session"] = new
        data["pod"] = new
        fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path), prefix=".tmux-group.", suffix=".tmp")
        try:
            with os.fdopen(fd, "w") as output:
                json.dump(data, output, indent=2)
                output.write("\n")
                output.flush()
                os.fsync(output.fileno())
            os.replace(tmp, path)
        except Exception:
            try:
                os.unlink(tmp)
            except OSError:
                pass
            raise
    finally:
        fcntl.flock(lock, fcntl.LOCK_UN)
PY
fi

# 3. announce in the pod's own feed (same format pod-kill-worker uses)
CHAN="$(pod_chan_for "$new")"
mkdir -p "$(dirname "$CHAN")" 2>/dev/null || true
echo "[$(date +%H:%M)] pod renamed $old -> $new" >> "$CHAN" 2>/dev/null || true
