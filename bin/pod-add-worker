#!/usr/bin/env bash
# pod-add-worker [--agent ID] [--model SLUG] [--effort SLUG] [--cmd "CMD"] [--label "CARD"] [@id]
# Spawn a colored worker window in the pod AND register it (the "+" button action).
#
#   no @id     -> spawn a NEW colored worker window
#   @id        -> just (re)color + register an existing window (fix a hand-opened one)
#
# Color = the first lib/palette entry not already used by another window's tab, so
# workers stay visually distinct. Dark jewel-tone bg + light fg (colour231) on body AND
# status — a bg without a light fg is the black-on-black bug (see lib/palette). Registers
# in $POD_STATE/workers.json (idempotent) so the optional queue/MCP can dispatch + poll
# it and it shows in `pod`. bash 3.2 safe.
set -uo pipefail
POD_BIN="$(cd "$(dirname "$0")" && pwd)"; . "$POD_BIN/_pod-paths.sh"
T="$POD_TMUX"
S="${POD_SESSION:-$POD_SESSION_PREFIX}"

# WORKER palette — SINGLE SOURCE is lib/palette (read by the MCP too). code + name per line.
COLORS=(); NAMES=()
while read -r code name _; do
  case "$code" in ''|\#*) continue ;; esac
  COLORS+=("$code"); NAMES+=("$name")
done < "$POD_PALETTE"
[ "${#COLORS[@]}" -gt 0 ] || { COLORS=(colour18 colour52 colour22 colour58); NAMES=(ocean maroon forest olive); }

AGENT=""; MODEL=""; EFFORT=""; CMD=""; LABEL=""; win=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --agent)  AGENT="${2:-}";  shift 2 ;;
    --model)  MODEL="${2:-}";  shift 2 ;;
    --effort) EFFORT="${2:-}"; shift 2 ;;
    --cmd)    CMD="${2:-}";    shift 2 ;;
    --label)  LABEL="${2:-}";  shift 2 ;;
    @*)       win="$1";        shift   ;;
    *)        shift                    ;;
  esac
done

# default agent/command: a bare spawn with nothing chosen is a plain shell worker —
# the universal floor that works with no AI agent installed.
[ -n "$AGENT" ] || AGENT="generic-shell"
[ -n "$CMD" ]   || CMD="${SHELL:-/bin/bash}"

if [ -z "$win" ]; then
  # Tab name = a random friendly human name; the real identity (agent · model · effort)
  # rides in #{@card}. pod-name avoids names already on a tab in this pod.
  wname="$("$POD_BIN/pod-name" "$S" 2>/dev/null)"
  [ -n "$wname" ] || wname="worker"
  launch="exec $CMD"
  # Append at the END of the window list (after the last window). Plain `-a -t $S`
  # inserts after the ACTIVE window, which dropped new agents in front of later ones,
  # so target the highest existing index explicitly.
  last="$("$T" list-windows -t "$S" -F '#{window_name} #{window_index}' 2>/dev/null \
          | awk '{print $NF}' | sort -n | tail -1)"
  [ -n "$last" ] && tgt="${S}:${last}" || tgt="$S"
  win="$("$T" new-window -a -t "$tgt" -n "$wname" -P -F '#{window_id}' "cd \"\$HOME\" && $launch")"
fi

# EMPTY-TARGET FOOTGUN guard: with no window id, every `setw -t "$win"` below would
# target "" — which tmux resolves to the ACTIVE window — and recolor/re-stamp identity
# onto whatever window the user is focused on. Abort instead.
if [ -z "$win" ]; then
  echo "$(date +%H:%M:%S) ERROR new-window failed (pod=$S tgt=${tgt:-?})" >> "$POD_STATE/pod-add-worker.log"
  exit 1
fi

# Color from the window's own numeric id as the STARTING index, then probe for a free
# one. The per-window starting offset is race-proof: concurrent spawns each begin from
# their own id, so a burst can't all converge on one "first free" color. With N colors,
# >N windows must repeat (pigeonhole); probing just avoids a clash while a free slot exists.
n=${#COLORS[@]}
idnum="$(printf '%s' "$win" | tr -dc '0-9')"
base=$(( ${idnum:-0} % n ))
used="$("$T" list-windows -t "$S" -F '#{window_id} #{window-status-style}' 2>/dev/null \
        | grep -v "^${win} " | grep -oE 'bg=colour[0-9]+' | sed 's/bg=//')"
c=""
for k in $(seq 0 $((n - 1))); do
  cand="${COLORS[$(( (base + k) % n ))]}"
  case " $(echo $used) " in *" ${cand} "*) continue ;; esac
  c="$cand"; break
done
[ -z "$c" ] && c="${COLORS[$base]}"

"$T" setw -t "$win" window-style                "fg=colour231,bg=$c"
"$T" setw -t "$win" window-active-style         "fg=colour231,bg=$c"
"$T" setw -t "$win" window-status-style         "bg=$c,fg=colour231"
# Active tab = the same two colors swapped EXPLICITLY, never via the `reverse`
# attribute — under reverse the strip format's #[fg=..] glyphs (state dot, kill ✕,
# gold ⭐) render swapped too, painting solid color blocks behind them on the
# selected tab. KEEP IN SYNC with _apply_tmux_color in modules/mcp.
"$T" setw -t "$win" window-status-current-style "bg=colour231,fg=$c"

# color NAME for the registry (matches the MCP's stored value)
cname=""
for i in "${!COLORS[@]}"; do [ "${COLORS[$i]}" = "$c" ] && cname="${NAMES[$i]}" && break; done

# Compose the identity CARD. Use the picker's pretty --label verbatim when given; else
# build one from the adapter catalog so a CLI spawn matches a menu spawn.
if [ -n "$LABEL" ]; then
  card="$LABEL"
  agent_pretty="$("$POD_ADAPTER" field "$AGENT" label 2>/dev/null || echo "$AGENT")"
else
  card="$("$POD_ADAPTER" card "$AGENT" --model "$MODEL" --effort "$EFFORT" 2>/dev/null)"
  agent_pretty="$("$POD_ADAPTER" field "$AGENT" label 2>/dev/null || echo "$AGENT")"
  [ -n "$card" ] || card="$agent_pretty"
fi

# Stamp identity. @agent_id is the cached detection key (set authoritatively here since
# we KNOW what we launched); @pod_native_delivery tells pod-deliver whether to send-keys.
nd="$("$POD_ADAPTER" field "$AGENT" native_delivery 2>/dev/null || echo false)"
"$T" set-option -w -t "$win" @card       "$card"
"$T" set-option -w -t "$win" @agent      "$agent_pretty"
"$T" set-option -w -t "$win" @agent_id   "$AGENT"
"$T" set-option -w -t "$win" @model      "$MODEL"
"$T" set-option -w -t "$win" @effort     "$EFFORT"
if [ "$nd" = "true" ]; then "$T" set-option -w -t "$win" @pod_native_delivery 1
else "$T" set-option -w -t "$win" @pod_native_delivery 0; fi

# register in workers.json (idempotent), fcntl-locked + atomic so concurrent +/✕/sync
# writers can't drop each other's entries. All three writers lock the SAME .lock file.
wname="$("$T" display-message -p -t "$win" '#{window_name}')"
HOSTSHORT="$(hostname -s 2>/dev/null || echo localhost)"
WORKERS="$POD_STATE/workers.json"
python3 - "$win" "$S" "$cname" "$wname" "$agent_pretty" "$MODEL" "$HOSTSHORT" "$EFFORT" "$card" "$AGENT" "$WORKERS" <<'PY'
import json, sys, os, fcntl, datetime, tempfile
wid, sess, color, label, agent_type, model, host, effort, card, agent_id, p = sys.argv[1:12]
os.makedirs(os.path.dirname(p), exist_ok=True)
lf = open(p + ".lock", "w")
fcntl.flock(lf, fcntl.LOCK_EX)
try:
    try:
        d = json.load(open(p))
        if not isinstance(d, dict):
            d = {"workers": []}
    except Exception:
        d = {"workers": []}
    ws = d.setdefault("workers", [])
    if not any(w.get("tmux_window") == wid for w in ws):
        ws.append({
            "window_id": None, "dispatch_mode": "tmux", "tmux_session": sess,
            "tmux_window": wid, "color": color, "agent_type": agent_type, "agent_id": agent_id,
            "model": model, "effort": effort, "card": card, "label": label, "host": host,
            "status": "idle", "current_task_id": None, "started_at": None,
            "registered_at": datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        })
        fd, tmp = tempfile.mkstemp(dir=os.path.dirname(p), prefix=".workers.", suffix=".tmp")
        with os.fdopen(fd, "w") as tf:
            json.dump(d, tf, indent=2)
        os.replace(tmp, p)
finally:
    fcntl.flock(lf, fcntl.LOCK_UN)
    lf.close()
PY
# Log to a FILE, not stdout: the + button runs this via tmux run-shell, which captures
# stdout and pops it as a copy-mode overlay on the new window (the "stuck color screen"
# bug). Empty stdout => no overlay.
echo "$(date +%H:%M:%S) $win $c $cname $AGENT" >> "$POD_STATE/pod-add-worker.log"
